# MirrorLife / 镜像人生 环境变量配置
#
# Phase 1 当前 demo 默认不需要环境变量即可运行。
# 本地模板叙事是默认 fallback，真实 LLM API 不作为 demo 阻塞项。

# 未来接入真实 LLM 时必须走后端代理，不要在浏览器前端暴露生产 API key。
# 以下变量仅作为后端代理或本地实验配置占位。

# LLM provider/model
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# LLM_PROXY_URL=http://localhost:8787/api/narrative

# Server-side only secrets
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Supabase（Phase 2 接入时启用）
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
